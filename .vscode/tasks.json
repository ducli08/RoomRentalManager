{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-backend",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/backend/RoomRentalManagerServer.API/RoomRentalManagerServer.API.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "stop-full-stack",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/stop-servers.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "start-dev-servers",
      "dependsOn": ["Backend (API)", "Frontend (Angular)"],
      "problemMatcher": []
    },
    {
      "label": "Backend (API)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/backend/RoomRentalManagerServer.API/RoomRentalManagerServer.API.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend/RoomRentalManagerServer.API"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "dotnet",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Now listening on:|Application started\\.)"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "group": "backend-only",
        "showReuseMessage": false
      }
    },
    {
      "label": "Frontend (Angular)",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "start"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Application bundle generation complete|bundle generation complete)"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "group": "frontend-only",
        "showReuseMessage": false
      }
    },
    {
      "label": "open-browser",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "start", "", "http://localhost:4200"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "Run Full Stack",
      "dependsOn": ["stop-full-stack", "start-dev-servers", "open-browser"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Stop Full Stack",
      "dependsOn": ["stop-full-stack"],
      "problemMatcher": []
    }
  ]
}
